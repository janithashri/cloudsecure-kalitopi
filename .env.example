SECRET_KEY=
DEBUG=True
POSTGRES_DB=cloudsecure
POSTGRES_USER=cloudsecure
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432
VALKEY_URL=redis://valkey:6379/0

# Neo4j AuraDB (recommended for production / public deployments)
# Create a free instance at https://neo4j.com/cloud/aura/ and paste connection details below.
NEO4J_URI=neo4j+s://YOUR_INSTANCE_ID.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_SHARED_DATABASE=neo4j

# Optional: override shared graph DB (defaults to NEO4J_* above)
# NEO4J_SHARED_URI=
# NEO4J_SHARED_USER=
# NEO4J_SHARED_PASSWORD=

# Optional: per-tenant Aura instances (leave blank to use shared Aura DB)
# NEO4J_TENANT_URI_TEMPLATE=neo4j+s://YOUR_TENANT_{tenant_id}.databases.neo4j.io
# NEO4J_TENANT_USER=
# NEO4J_TENANT_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
ENABLE_AWS_CONFIG_DRIFT=false
AWS_CONFIG_REGION=
AWS_CONFIG_INITIAL_LOOKBACK_MINUTES=180

# Host path to Stratus CloudTrail dataset (mounted read-only at /data/aws_dataset in celery)
ANOMALY_DATASET_HOST_PATH=./data/aws_dataset
